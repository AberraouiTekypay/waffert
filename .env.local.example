# Waffert Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase (required for database features)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin dashboard password (simple gate — replace with proper auth for production)
NEXT_PUBLIC_ADMIN_PASSWORD=waffert2026

# Resend (for email notifications)
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=hello@waffert.com

# Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# Calendly (for consultation booking)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/waffert/consultation
